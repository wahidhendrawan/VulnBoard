{
  "name": "vulnboard-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node-dev --transpile-only src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.6.0",
    "fast-xml-parser": "^5.10.1",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.7",
    "multer": "^2.2.0",
    "puppeteer": "^25.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "prisma": "^7.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^7.0.2"
